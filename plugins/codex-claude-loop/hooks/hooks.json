{
  "description": "Platform gate for codex-claude-loop subagent routing.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CODEX_PLUGIN_ROOT}/hooks/subagent-gate-hook.mjs\"",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CODEX_PLUGIN_ROOT}/hooks/subagent-gate-hook.mjs\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|spawn_agent|Task|subagent|agent|worker|mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CODEX_PLUGIN_ROOT}/hooks/subagent-gate-hook.mjs\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
